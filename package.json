{
  "name": "vc6-impact-review",
  "displayName": "VC6 Impact Review",
  "description": "Visualize global-variable and function impact in large VC6 C/C++ projects without writing to the target source tree.",
  "version": "0.2.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/katamor1/vscodeTree.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vc6Impact.buildFullIndex",
    "onCommand:vc6Impact.updateIndex",
    "onCommand:vc6Impact.inspectSelectedSymbol",
    "onCommand:vc6Impact.generateReviewReport",
    "onCommand:vc6Impact.openGraph",
    "onView:vc6Impact.explorer"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "resources/**",
    "native/vc6-impact-rust/target/release/vc6-impact-rust.exe",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "configuration": {
      "title": "VC6 Impact Review",
      "properties": {
        "vc6Impact.projectFile": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative path to the VC6 .dsw or .dsp file. Empty means auto-detect the first .dsw, then .dsp."
        },
        "vc6Impact.threadMapFile": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative JSON/YAML file that maps thread IDs to entry functions."
        },
        "vc6Impact.outputDir": {
          "type": "string",
          "default": "",
          "description": "Directory for index and reports. Empty uses <workspace>/.vscode/vc6-impact-review and adds it to .git/info/exclude when possible."
        },
        "vc6Impact.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/Debug/**",
            "**/Release/**",
            "**/node_modules/**",
            "**/.git/**"
          ],
          "description": "Glob-like path fragments to exclude while scanning source files."
        },
        "vc6Impact.maxGraphDepth": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum call graph depth shown in graph/report views."
        },
        "vc6Impact.maxIndexWorkers": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 64,
          "description": "Maximum worker threads used while building indexes. 0 means auto (CPU count - 1)."
        },
        "vc6Impact.indexDbPath": {
          "type": "string",
          "default": "",
          "description": "Optional explicit path to the JSON index DB. Empty stores vc6-impact-index.json under outputDir."
        },
        "vc6Impact.projectEncoding": {
          "type": "string",
          "enum": [
            "auto",
            "utf8",
            "cp932"
          ],
          "default": "auto",
          "description": "Encoding for VC6 .dsw/.dsp project files. auto tries UTF-8 BOM, UTF-8, then CP932."
        },
        "vc6Impact.sourceEncoding": {
          "type": "string",
          "enum": [
            "auto",
            "utf8",
            "cp932"
          ],
          "default": "auto",
          "description": "Encoding for C/C++ source files scanned by the Rust sidecar. auto tries UTF-8 BOM, UTF-8, then CP932."
        }
      }
    },
    "commands": [
      {
        "command": "vc6Impact.buildFullIndex",
        "title": "Build Full Index",
        "shortTitle": "Build",
        "category": "VC6 Impact",
        "icon": "$(database)"
      },
      {
        "command": "vc6Impact.updateIndex",
        "title": "Update Index",
        "shortTitle": "Update",
        "category": "VC6 Impact",
        "icon": "$(refresh)"
      },
      {
        "command": "vc6Impact.inspectSelectedSymbol",
        "title": "Inspect Selected Symbol",
        "shortTitle": "Inspect",
        "category": "VC6 Impact",
        "icon": "$(search)"
      },
      {
        "command": "vc6Impact.generateReviewReport",
        "title": "Generate Review Report",
        "shortTitle": "Report",
        "category": "VC6 Impact",
        "icon": "$(file-text)"
      },
      {
        "command": "vc6Impact.openGraph",
        "title": "Open Graph",
        "shortTitle": "Graph",
        "category": "VC6 Impact",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vc6Impact.inspectSelectedSymbol",
          "group": "navigation@50"
        },
        {
          "command": "vc6Impact.generateReviewReport",
          "group": "navigation@51"
        }
      ],
      "view/title": [
        {
          "command": "vc6Impact.buildFullIndex",
          "when": "view == vc6Impact.explorer",
          "group": "navigation@1"
        },
        {
          "command": "vc6Impact.updateIndex",
          "when": "view == vc6Impact.explorer",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vc6Impact",
          "title": "VC6 Impact",
          "icon": "resources/activitybar.svg"
        }
      ]
    },
    "views": {
      "vc6Impact": [
        {
          "id": "vc6Impact.explorer",
          "name": "Impact Review"
        }
      ]
    }
  },
  "scripts": {
    "precompile": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "test": "vitest run",
    "watch": "tsc -watch -p ./",
    "check": "npm run test && npm run compile",
    "bench:index": "node scripts/benchmark-index.js",
    "samples:enrich-members": "node scripts/enrich-member-samples.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
